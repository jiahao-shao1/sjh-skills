    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" post-knowledge-remind",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__cluster__remote_bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" post-knowledge-remind",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
